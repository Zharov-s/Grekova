# Mail.ru / Mail SMTP for ABCENTRUM mailing — Грекова
# Copy this file to .env locally or set these variables as Codex/runtime secrets.
# Do NOT commit .env and do NOT store the real SMTP_PASS in markdown or source files.

SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=s.zharov@abcentrum.ru
SMTP_PASS=PASTE_APP_PASSWORD_HERE
EMAIL_FROM="ABCENTRUM <s.zharov@abcentrum.ru>"
EMAIL_TO=s.zharov@abcentrum.ru
EMAIL_CC=s.zharov@abcentrum.ru
EMAIL_REPLY_TO=s.zharov@abcentrum.ru

# Public HTTPS URL where the files from ./assets are hosted.
ASSET_BASE_URL=https://raw.githubusercontent.com/Zharov-s/Grekova/main/assets

# Real unsubscribe URL. Can be a web form or temporary mailto link.
UNSUBSCRIBE_URL=mailto:s.zharov@abcentrum.ru?subject=Отписка%20от%20рассылки%20ABCENTRUM
